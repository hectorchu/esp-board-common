# Camera viewfinder — shared settings for all boards

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Task watchdog
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10

# CSI camera (ESP32-P4 boards with OV5647)
CONFIG_CAMERA_OV5647=y
CONFIG_CAMERA_OV5647_MIPI_RAW8_800x1280_50FPS=y
CONFIG_ESP_VIDEO_ENABLE_ISP_PIPELINE_CONTROLLER=y
# Allow CSI driver to allocate its internal backup buffer for DMA safety
# CONFIG_ESP_VIDEO_DISABLE_MIPI_CSI_DRIVER_BACKUP_BUFFER is not set

# Disable task WDT — camera DQBUF blocks the idle task
CONFIG_ESP_TASK_WDT_EN=n
# FreeRTOS timer task needs more stack for camera/ISP
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=4096
